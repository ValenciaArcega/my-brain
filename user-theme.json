          "settings": {
            "foreground": "#E4DC82"
          }
        },
        {
          "scope": [
            "meta.brace.round.tsx"
          ],
          "settings": {
            "foreground": "#8a8b8a"
          }
        },
        {
          "scope": [
            "keyword.control"
          ],
          "settings": {
            "fontStyle": "underline",
            "foreground": "#ffbaf5"
          }
        },
        {
          "scope": [
            "constant.language"
          ],
          "settings": {
            "fontStyle": "",
            "foreground": "#c3fae8"
          }
        },
        {
          "scope": [
            "comment",
            "punctuation.definition.comment.tsx",
          ],
          "settings": {
            "foreground": "#7b7b7b"
          }
        },
        {
          "scope": [
            ""
          ],
          "settings": {
            "foreground": "#A2C581"
          }
        },
        {
          "scope": [
            "entity.other.attribute-name"
          ],
          "settings": {
            "fontStyle": "",
            "foreground": "#d3f5fb"
          }
        },
        {
          "scope": [
            "punctuation.section.embedded"
          ],
          "settings": {
            "foreground": "#fff"
          }
        },
        {
          "scope": [
            "keyword.operator.expression.of.tsx"
          ],
          "settings": {
            "foreground": "#ffbaf5"
          }
        }
      ]
    },
    "[VS Code Light]": {
      "textMateRules": [
        {
          "scope": [
            "keyword",
            "storage.modifier",
