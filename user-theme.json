          }
        },
        {
          "scope": [
            "constant.language"
          ],
          "settings": {
            "fontStyle": "",
            "foreground": "#000"
          }
        },
        {
          "scope": [
            "comment"
          ],
          "settings": {
            "foreground": "#43b370"
