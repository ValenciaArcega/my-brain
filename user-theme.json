          ],
          "settings": {
            "fontStyle": "underline",
            "foreground": "#EE81B0"
          }
        },
        {
          "scope": [
            "keyword.operator.new.tsx"
          ],
          "settings": {
            "foreground": "#d2f6ef"
          }
        },
        {
          "scope": [
            "keyword.control.conditional"
          ],
          "settings": {
            "fontStyle": "",
            "foreground": "#ffec99"
          }
        },
        {
          "scope": [
            "storage.modifier.async"
          ],
          "settings": {
            "fontStyle": "underline",
            "foreground": "#faf3a2"
          }
        },
        {
          "scope": [
            "entity.name.function"
